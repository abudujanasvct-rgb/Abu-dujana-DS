# Copy this file to .env and fill in your real values.
# NEVER commit the real .env file to GitHub.

# Get this from MongoDB Atlas after creating your free M0 cluster
# Replace <db_password> with your real database user password (NOT your Atlas login password)
MONGODB_URI=mongodb+srv://abudujanasvct_db_user:<db_password>@clusterofabu.nol4xhl.mongodb.net/portfolio?retryWrites=true&w=majority&appName=Clusterofabu

# Generate a long random string for this, e.g. run: openssl rand -base64 48
JWT_SECRET=replace_this_with_a_long_random_string

# Your real frontend domain(s), comma separated. Add localhost while developing.
ALLOWED_ORIGINS=http://localhost:5173,https://your-portfolio.vercel.app

# WebAuthn settings - RP_ID must match your real domain in production (no https://, no path)
RP_ID=localhost
ORIGIN=http://localhost:5173

PORT=5000
